# CASCADE Docker Compose Configuration
# Copy to .env and adjust values.

# --- PostgreSQL ---
POSTGRES_PASSWORD=cascade

# --- Ports ---
DASHBOARD_PORT=3001
ROUTER_PORT=3000

# --- Worker ---
MAX_WORKERS=3
WORKER_MEMORY_MB=4096
WORKER_TIMEOUT_MS=1800000

# --- Security (optional) ---
# CREDENTIAL_MASTER_KEY=  # Generate: openssl rand -hex 32
# CORS_ORIGIN=            # e.g. https://cascade.yourdomain.com
# COOKIE_DOMAIN=          # e.g. yourdomain.com

# --- Claude Code Backend (optional) ---
# CLAUDE_CODE_OAUTH_TOKEN=  # From: claude setup-token

# --- Monitoring (optional) ---
# SENTRY_DSN=

# --- Debugging (optional) ---
# LOG_LEVEL=info  # debug, info, warn, error
