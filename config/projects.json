{
	"_comment": "This file is a seeding example for initial setup. It is NOT used at runtime — all project configuration lives in the database. Use 'npm run db:seed -- --org <org-id>' to import.",
	"defaults": {
		"model": "openrouter:google/gemini-3-flash-preview",
		"maxIterations": 70,
		"agentModels": {
			"planning": "openrouter:google/gemini-3-pro-preview",
			"review": "openrouter:google/gemini-3-pro-preview",
			"implementation": "openrouter:deepseek/deepseek-v3.2"
		},
		"agentIterations": {
			"planning": 50,
			"splitting": 50
		},
		"watchdogTimeoutMs": 2700000,
		"selfDestructTimeoutMs": 1800000,
		"postJobGracePeriodMs": 45000,
		"workItemBudgetUsd": 5.00
	},
	"projects": [
		{
			"id": "my-project",
			"name": "my-project",
			"repo": "your-org/your-repo",
			"baseBranch": "dev",
			"branchPrefix": "feature/",

			"trello": {
				"boardId": "your-trello-board-id",
				"lists": {
					"splitting": "your-splitting-list-id",
					"planning": "your-planning-list-id",
					"todo": "your-todo-list-id",
					"inProgress": "your-in-progress-list-id",
					"inReview": "your-in-review-list-id",
					"done": "your-done-list-id",
					"merged": "your-merged-list-id",
					"debug": "your-debug-list-id"
				},
				"labels": {
					"readyToProcess": "your-ready-to-process-label-id",
					"processing": "your-processing-label-id",
					"processed": "your-processed-label-id",
					"error": "your-error-label-id"
				},
				"customFields": {
					"cost": "your-cost-custom-field-id"
				}
			}
		},
		{
			"id": "claude-code-project",
			"name": "claude-code-project",
			"repo": "your-org/another-repo",
			"baseBranch": "dev",
			"branchPrefix": "feature/",

			"agentEngine": {
				"default": "llmist",
				"overrides": {
					"implementation": "claude-code",
					"respond-to-review": "claude-code",
					"respond-to-ci": "claude-code",
					"respond-to-pr-comment": "claude-code"
				}
			},
			"agentModels": {
				"planning": "openrouter:google/gemini-3-flash-preview",
				"review": "openrouter:google/gemini-3-flash-preview"
			},
			"trello": {
				"boardId": "your-trello-board-id",
				"lists": {
					"splitting": "your-splitting-list-id",
					"planning": "your-planning-list-id",
					"todo": "your-todo-list-id",
					"inProgress": "your-in-progress-list-id",
					"inReview": "your-in-review-list-id",
					"done": "your-done-list-id",
					"merged": "your-merged-list-id",
					"debug": "your-debug-list-id"
				},
				"labels": {
					"readyToProcess": "your-ready-to-process-label-id",
					"processing": "your-processing-label-id",
					"processed": "your-processed-label-id",
					"error": "your-error-label-id"
				},
				"customFields": {
					"cost": "your-cost-custom-field-id"
				}
			}
		}
	]
}
