# Trello API credentials
TRELLO_API_KEY=
TRELLO_TOKEN=

# GitHub tokens for dual-persona model (implementer + reviewer bots)
GITHUB_TOKEN_IMPLEMENTER=
GITHUB_TOKEN_REVIEWER=

# LLM API keys
OPENROUTER_API_KEY=

# Server configuration
PORT=3000
LOG_LEVEL=info

# Redis — required for router mode (BullMQ job queue for webhook processing)
# Run: brew install redis && brew services start redis (macOS)
#      apt-get install redis-server && service redis-server start (Linux)
# The .cascade/setup.sh script installs and starts Redis automatically.
REDIS_URL=redis://localhost:6379

# Optional: Path to projects config file
# CONFIG_PATH=./config/projects.json

# Credential encryption at rest (AES-256-GCM)
# Generate with: npm run credentials:generate-key
# When set, all new/updated credentials are encrypted automatically.
# Existing plaintext credentials continue to work and can be migrated with: npm run credentials:encrypt
# CREDENTIAL_MASTER_KEY=
