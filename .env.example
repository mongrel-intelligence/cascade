# =============================================================================
# CASCADE — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#
# NOTE: Project-level credentials (GitHub tokens, Trello/JIRA API keys, LLM
# API keys) are stored in the DATABASE — not in this file. Only infrastructure
# connection strings are required here. Use `cascade credentials create` or
# the dashboard to manage project credentials after initial setup.
# =============================================================================

# --- Required: Infrastructure ---

# PostgreSQL connection string (Supabase transaction pooler uses port 6543)
DATABASE_URL=postgresql://user:password@localhost:5432/cascade

# Redis connection string (required for BullMQ job queue)
# Run: brew install redis && brew services start redis  (macOS)
#      apt-get install redis-server && service redis-server start  (Linux)
REDIS_URL=redis://localhost:6379

# --- Optional: Server ---

PORT=3000
LOG_LEVEL=info

# Disable SSL for local PostgreSQL (set to false for local dev without SSL)
# DATABASE_SSL=false

# --- Optional: Security ---

# AES-256-GCM encryption key for credentials stored in the database.
# Generate with: npm run credentials:generate-key
# When set, all new/updated credentials are encrypted automatically.
# Existing plaintext credentials continue to work and can be migrated:
#   npm run credentials:encrypt  (encrypt existing)
#   npm run credentials:decrypt  (rollback to plaintext)
# CREDENTIAL_MASTER_KEY=

# --- Optional: Claude Code Backend ---

# OAuth token for Claude Code SDK (Claude Max subscription).
# Generate with: claude setup-token
# See CLAUDE.md for full setup instructions.
# CLAUDE_CODE_OAUTH_TOKEN=

# --- Optional: Monitoring ---

# Sentry DSN for error monitoring (router + worker)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.1
